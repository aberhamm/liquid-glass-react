{
  "name": "@aberhamm/liquid-glass-react",
  "version": "0.1.0",
  "description": "An independent React reimplementation of a liquid-glass UI component library.",
  "type": "module",
  "license": "MIT",
  "author": "Matthew Aberham",
  "keywords": [
    "react",
    "liquid-glass",
    "glassmorphism",
    "backdrop-filter",
    "svg-filter",
    "displacement-map",
    "glass",
    "ui",
    "components",
    "refraction"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aberhamm/liquid-glass-react.git"
  },
  "homepage": "https://github.com/aberhamm/liquid-glass-react#readme",
  "bugs": {
    "url": "https://github.com/aberhamm/liquid-glass-react/issues"
  },
  "packageManager": "pnpm@10.33.3",
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/liquid-glass-react.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "e2e": "pnpm build-storybook && playwright test",
    "e2e:ui": "pnpm build-storybook && playwright test --ui",
    "attw": "attw --pack . --exclude-entrypoints ./styles.css",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
